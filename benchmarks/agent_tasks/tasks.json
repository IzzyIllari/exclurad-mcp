      "id": "fx-01",
      "class": "fixable",
      "request": "Eta: scan cos theta* from -1 to +1 in 5 steps at W = 1.7, Q2 = 1.5, phi* = 90.",
      "channel": "eta",
      "ground_truth": {
        "expected_action": "fix_and_generate",
        "n_points": 5,
        "required_fix": "cos_clamped",
        "fix_detail": "endpoints +/-1 must become +/-0.999 (the validated convention); the raw endpoints FAIL preflight",
        "must_mention_any": [
          "0.999",
          "pole"
        ],
        "verify": {
          "points": [
            [
              1.7,
              1.5,
              -1.0,
              90.0
